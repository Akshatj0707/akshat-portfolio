# ════════════════════════════════════════════════════════
#  Akshat Jain Portfolio — Environment Variables
#  Copy to .env  →  fill values  →  NEVER commit .env
# ════════════════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development

# MongoDB (Atlas free M0 — get from cloud.mongodb.com)
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/akshat_portfolio

# JWT Secret (any 32+ char random string)
JWT_SECRET=AkshatJain_Portfolio_JWT_SecretKey_2024_ChangeThis!

# Stripe (get from dashboard.stripe.com → Developers → API Keys)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Admin Login for /admin.html
ADMIN_EMAIL=akshatjain9804@gmail.com
ADMIN_PASSWORD=Admin@Akshat2024!

# Email Notifications (Gmail App Password — NOT your real password)
# Enable at: myaccount.google.com/apppasswords
EMAIL_USER=akshatjain9804@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_TO=akshatjain9804@gmail.com

# Set this AFTER deploying to Render (paste your Render URL)
FRONTEND_URL=https://akshat-portfolio.onrender.com
